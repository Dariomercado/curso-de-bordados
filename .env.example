# Database
DATABASE_URL=

# Auth.js / NextAuth
NEXTAUTH_SECRET=

# Public URLs
# In deploy, NEXTAUTH_URL, NEXT_PUBLIC_SITE_URL and AUTH_EMAIL_BASE_URL must point to the public domain.
NEXTAUTH_URL=
NEXT_PUBLIC_SITE_URL=

# Transactional email
# Use AUTH_EMAIL_PROVIDER=console only for local/dev.
# Use AUTH_EMAIL_PROVIDER=resend for production.
AUTH_EMAIL_PROVIDER=
RESEND_API_KEY=
AUTH_EMAIL_FROM=
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_BASE_URL=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# Local/dev only. Never enable this in production.
MERCADO_PAGO_ALLOW_UNSIGNED_WEBHOOK_DEV=
